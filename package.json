{
  "name": "imgro",
  "version": "1.2.0",
  "description": "Imgro - Image Resizer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --linux",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --linux",
    "pack": "electron-builder --dir"
  },
  "author": {
    "name": "nxxtt",
    "email": "osvaldo.kuhn.dantas@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "42.0.1",
    "electron-builder": "26.9.1",
    "eslint": "^10.3.0"
  },
  "build": {
    "appId": "com.imgro.app",
    "productName": "Imgro",
    "icon": "assets/icon.png",
    "directories": {
      "output": "dist-v4"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [],
      "extraFiles": []
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Graphics"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createStartMenuShortcut": true,
      "createDesktopShortcut": "always",
      "installerLanguages": [
        "en-US"
      ],
      "language": "1033",
      "artifactName": "ImgroSetup.exe",
      "useZip": true
    },
    "portable": {
      "artifactName": "Imgrop.exe",
      "useZip": true
    },
    "appImage": {
      "artifactName": "Imgro-${version}.${ext}"
    },
    "deb": {
      "artifactName": "Imgro-${version}.${ext}"
    },
    "rpm": {
      "artifactName": "Imgro-${version}.${ext}"
    },
    "publish": null,
    "asar": true,
    "compression": "store",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ]
  }
}
