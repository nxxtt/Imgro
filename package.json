{
  "name": "imgro",
  "version": "1.0.0",
  "description": "Imgro - Image Resizer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.4.0",
    "electron-builder": "^26.9.0"
  },
  "build": {
    "appId": "com.imgro.app",
    "productName": "Imgro",
    "icon": "C:\\Users\\Osvaldo\\Downloads\\ChatGPT Image 1 de mai. de 2026, 11_40_27.png",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createStartMenuShortcut": true,
      "createDesktopShortcut": "always",
      "installerLanguages": ["en-US"],
      "language": "1033",
      "artifactName": "ImgroSetup.exe"
    },
    "portable": {
      "artifactName": "Imgrop.exe"
    },
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ]
  }
}